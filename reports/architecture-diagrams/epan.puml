@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title C4 Level 2: Container Diagram for Wireshark (EPAN Focus)

Person(user, "Network Analyst", "Analyzes and decodes network traffic.")

System_Ext(os_net, "Network Interfaces (OS)", "Raw packets via libpcap/Npcap.")
System_Ext(file_system, "Local File System", "pcap/pcapng files, Lua scripts, decryption keys, GeoIP databases.")
System_Ext(c_ares, "c-ares", "Async DNS library used by EPAN for IP-to-hostname resolution.")
System_Ext(libgcrypt, "libgcrypt", "Cryptographic library used directly by EPAN for decryption.")

System_Boundary(wireshark_sys, "Wireshark Network Analyzer") {
    Container(gui, "Wireshark GUI", "C++, Qt", "Graphical interface: protocol tree, packet bytes, statistics.")
    Container(tshark, "TShark CLI", "C", "CLI for automated analysis and filtering.")
    Container(dumpcap, "Dumpcap", "C", "Privileged capture subprocess. Captures live traffic and writes pcapng to disk.")
    Container(wiretap, "Wiretap (libwiretap)", "C Library", "Abstracts file I/O across dozens of capture formats.")
    Container(wsutil, "WSUtil (libwsutil)", "C Library", "Shared utilities: wmem allocator, string/inet helpers, logging.")
    Container(epan, "EPAN (libwireshark)", "C/C++ Library", "Core dissection engine. Dissects raw frames via protocol dissectors, produces proto_tree. Includes addr_resolv and maxmind_db modules.")
}

' User
Rel(user, gui, "Interacts with", "UI Events")
Rel(user, tshark, "Executes", "CLI")

' Capture path: GUI/TShark spawn Dumpcap as child process
Rel(gui, dumpcap, "Spawns as child process, controls via", "sync_pipe (bidirectional)")
Rel(tshark, dumpcap, "Spawns as child process, controls via", "sync_pipe (bidirectional)")
Rel(dumpcap, os_net, "Captures packets", "libpcap / Npcap API")
Rel(dumpcap, file_system, "Writes capture files", "pcapng")

' File reading
Rel(gui, wiretap, "Requests packet data", "C API")
Rel(tshark, wiretap, "Requests packet data", "C API")
Rel(wiretap, file_system, "Reads/Writes capture files", "File I/O")

' Dissection
Rel(gui, epan, "Requests dissection, applies display filters", "C API")
Rel(tshark, epan, "Requests dissection, applies display filters", "C API")

' EPAN dependencies
Rel(epan, wsutil, "Uses wmem allocator, inet/string helpers", "C API")
Rel(epan, libgcrypt, "Performs protocol decryption", "C API")
Rel(epan, c_ares, "Resolves IPs to hostnames", "c-ares API")
Rel(epan, file_system, "Reads GeoIP DBs (maxmind_db), keys", "File I/O")

@enduml