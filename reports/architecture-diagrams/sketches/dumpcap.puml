@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title C4 Level 3: Component Diagram for Dumpcap (Privilege Separation)

' External Dependencies (Outside the Dumpcap boundary)
System(wireshark, "Wireshark (GUI / TShark)", "Parent process. Sends control commands and reads real-time statistics.")
System_Ext(file_system, "Local File System", "Stores the automatically rotated temporary pcapng files.")
System_Ext(libpcap_npcap, "OS Network Interfaces (libpcap / Npcap)", "External libraries providing raw network frames from the kernel.")

' Dumpcap Boundary
Container_Boundary(dumpcap_res, "Dumpcap (Privileged Executable)") {
    
    Component(sync_pipe, "Syncpipe Controller", "C Code", "Manages IPC communication and control signals with the parent process.")
    Component(priv_mgr, "Privilege Manager", "C Code", "Opens the socket as root and immediately drops privileges.")
    Component(cap_eng, "Capture Engine", "C Code", "Interfaces with the OS network libraries to fetch raw frames.")
    Component(bpf_mgr, "Capture Filter Manager", "C Code", "Compiles and applies BPF (Berkeley Packet Filter) logic.")
    Component(file_writer, "Ring Buffer & File Writer", "C Code", "Manages asynchronous writing and automatic rotation of pcapng files.")
}

' Unidirectional Relationships (Dependency / Call Direction)
Rel(wireshark, sync_pipe, "Sends commands & reads stats", "IPC Pipe")
Rel(sync_pipe, priv_mgr, "Initializes capture session", "Internal Call")
Rel(sync_pipe, file_writer, "Reads active file state & counters", "Internal Call")
Rel(priv_mgr, cap_eng, "Configures secure socket", "Internal Call")
Rel(cap_eng, libpcap_npcap, "Polls for raw packets", "Library API")
Rel(cap_eng, bpf_mgr, "Passes packets for filtering", "Internal Call")
Rel(bpf_mgr, file_writer, "Forwards accepted packets", "Memory Buffer")
Rel(file_writer, file_system, "Writes packet blocks", "Asynchronous I/O (.pcapng)")

@enduml